# Copy this file to .env and fill in your own values. Never commit .env.
# Only needed if you use AzureOpenAIEmbedder (pip install corticore[openai]).
# The default corticore setup (LocalEmbedder + SQLiteStore) needs none of this.

AZURE_OPENAI_API_KEY=your-azure-openai-resource-key
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name

# Only needed if you use PostgresStore (pip install corticore[postgres]).
DATABASE_URL=postgresql://user:password@localhost:5432/corticore

# Only needed to run orchestrate/run_cloud_agent.py locally by hand (pip
# install corticore[orchestrate]). This is NOT how the scheduled
# .github/workflows/paper-loop.yml workflow gets its key - GitHub Actions
# runners can't see your local .env file, so that workflow requires
# CURSOR_API_KEY to be set as a GitHub Actions repository secret instead
# (repo Settings -> Secrets and variables -> Actions -> New repository
# secret). See research/design/adr/0005-scheduled-cloud-agent-research-loop.md.
CURSOR_API_KEY=your-cursor-api-key
